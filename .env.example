# ============================================================================
# SCS IMPORT DO — Example environment file
# ----------------------------------------------------------------------------
# Copy this file to  server/.env  and fill in real values.
# NEVER commit the real .env file. All secrets are SERVER-SIDE ONLY.
# See docs/ENVIRONMENT_SETUP.md for a full walkthrough.
# ============================================================================

# --- Server ---------------------------------------------------------------
PORT=4000
NODE_ENV=development
# Comma-separated list of origins allowed to call the API (the frontend URL).
CORS_ORIGIN=http://localhost:5173

# --- Auth (JWT; users live in the Google Sheet USERS tab) ----------------
# JWT_SECRET signs login tokens — use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# First-run admin (created automatically if the USERS tab is empty):
ADMIN_EMAIL=admin@fitsexpress.io
ADMIN_PASSWORD=change-me
ADMIN_NAME=Administrator

# --- Google (Sheets + Apps Script PDF — ONE service account) -------------
# See docs/GOOGLE_SHEETS_SETUP.md and docs/APPS_SCRIPT_SETUP.md.
# Spreadsheet ID (from the URL: docs.google.com/spreadsheets/d/<ID>/edit)
GOOGLE_SHEET_ID=your-google-sheet-id-here
GOOGLE_SHEET_TAB=SCS_IMPORT_DO_HISTORY
GOOGLE_USERS_TAB=USERS

# Google Slides template ({{merge tag}} Delivery Order), filled by the Apps Script.
GOOGLE_SLIDES_TEMPLATE_ID=your-slides-template-id-here
# Apps Script web app that renders the PDF (see docs/APPS_SCRIPT_SETUP.md):
APPS_SCRIPT_URL=
APPS_SCRIPT_SECRET=

# Service-account credentials — provide ONE of these (JSON is checked first):
#   1) GOOGLE_SERVICE_ACCOUNT_JSON — the FULL key JSON on one line. REQUIRED on
#      Vercel/any serverless or cloud host (there is no filesystem there).
GOOGLE_SERVICE_ACCOUNT_JSON=
#   2) GOOGLE_SERVICE_ACCOUNT_FILE — path to the key file. LOCAL DEV ONLY (do not
#      use on Vercel — the file is git-ignored and not deployed).
GOOGLE_SERVICE_ACCOUNT_FILE=./google-service-account.json

# Downloaded PDF filename prefix -> DO_<SerialNo>.pdf
PDF_FILENAME_PREFIX=DO
